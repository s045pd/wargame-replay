{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Full Stack (Server + Web)",
      "configurations": ["Go: Server", "Vite: Dev Server"],
      "stopAll": true
    }
  ],
  "configurations": [
    {
      "name": "Go: Server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/server",
      "args": ["-dir", "${workspaceFolder}/../", "-port", "8081"],
      "env": {
        "CGO_ENABLED": "1"
      },
      "cwd": "${workspaceFolder}/server"
    },
    {
      "name": "Go: Server (Custom Dir)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/server",
      "args": ["-dir", "${input:dataDir}", "-port", "8081"],
      "env": {
        "CGO_ENABLED": "1"
      },
      "cwd": "${workspaceFolder}/server"
    },
    {
      "name": "Vite: Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/web",
      "console": "integratedTerminal"
    },
    {
      "name": "Chrome: Frontend",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/web/src",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    },
    {
      "name": "Go: Test Current Package",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "env": {
        "CGO_ENABLED": "1"
      }
    }
  ],
  "inputs": [
    {
      "id": "dataDir",
      "type": "promptString",
      "description": "Path to directory containing .db game files",
      "default": "${workspaceFolder}/../"
    }
  ]
}
