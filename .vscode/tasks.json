{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build All",
      "type": "shell",
      "command": "make build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$go", "$tsc"]
    },
    {
      "label": "Build Frontend",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/web" },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Go Test All",
      "type": "shell",
      "command": "go test -race -count=1 ./...",
      "options": { "cwd": "${workspaceFolder}/server" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": "$go"
    },
    {
      "label": "Go Vet",
      "type": "shell",
      "command": "go vet ./...",
      "options": { "cwd": "${workspaceFolder}/server" },
      "group": "test",
      "problemMatcher": "$go"
    },
    {
      "label": "Frontend Lint",
      "type": "shell",
      "command": "npm run lint",
      "options": { "cwd": "${workspaceFolder}/web" },
      "group": "test"
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "make clean"
    }
  ]
}
